# Root env example
#
# For local dev, copy this to `.env`:
#   cp .env.example .env
#
# If you prefer, you can also start from `configs/env/.env.example`.

# Required (system boots only with these)
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/sovereign_engine
REDIS_URL=redis://localhost:6379

# Container-native URLs used by docker-compose.prod.yml when services run inside Docker.
CONTAINER_DATABASE_URL=postgresql://postgres:password@postgres:5432/sovereign_engine?sslmode=disable
CONTAINER_REDIS_URL=redis://redis:6379

# Domain-based deployment (no path)
APP_DOMAIN=localhost:3000
APP_PROTOCOL=http

# SMTP sending (worker + real delivery)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_user
SMTP_PASS=your_pass
SMTP_SECURE=false

# Enterprise security hardening
LOG_FORMAT=json
TLS_MIN_VERSION=TLSv1.3
REQUIRE_INTERNAL_TLS=false
# 32-byte base64 or 64-char hex key. Generate with:
# openssl rand -base64 32
SECRET_MASTER_KEY_ID=v1
SECRET_MASTER_KEY=
SECRET_MASTER_KEYS=
LOG_MAX_SIZE=50m
LOG_MAX_FILE=10
LOG_ARCHIVE_S3_URI=
LOG_ARCHIVE_AFTER_DAYS=30
LOG_ARCHIVE_STORAGE_CLASS=DEEP_ARCHIVE
SENDER_MIN_REPLICAS=2
SENDER_MAX_REPLICAS=24
AUTOSCALE_CPU_HIGH=70
AUTOSCALE_CPU_LOW=25
AUTOSCALE_MEM_HIGH=80
AUTOSCALE_TARGET_WAITING_PER_REPLICA=500
AUTOSCALE_QUEUE_HIGH=1000
AUTOSCALE_QUEUE_LOW=25
AUTOSCALE_SCALE_DOWN_IDLE_WINDOWS=4
AUTOSCALE_DRY_RUN=false

# Safe scale-proof mode. Keep false for real delivery; use true for demos/stress tests.
MOCK_SMTP=false
MOCK_SMTP_FASTLANE=false

# Email verification (required for safe sending)
ZEROBOUNCE_API_KEY=your_zerobounce_key

# Optional (protect cron endpoints; has a safe default for dev/demo)
# CRON_SECRET=change_me

# Optional alert delivery
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# ALERT_EMAIL_TO=ops@yourcompany.com
# ALERT_EMAIL_FROM=alerts@yourcompany.com
# ALERT_DELIVER_MIN_SEVERITY=high

# Optional Telegram operator feed
# TELEGRAM_BOT_TOKEN=123456:bot_token
# TELEGRAM_CHAT_ID=123456789
TELEGRAM_NOTIFICATIONS_ENABLED=true
TELEGRAM_NOTIFY_SENT=true
TELEGRAM_NOTIFY_FAILED=true
TELEGRAM_NOTIFY_IMPORTS=true
TELEGRAM_NOTIFY_APPROVALS=true
TELEGRAM_NOTIFY_QUEUE=true
TELEGRAM_FULL_EMAILS=false

# Optional global safety caps (sender-worker)
# GLOBAL_SENDS_PER_MINUTE=120
# XV_REGION=local
# SENDER_WORKER_CONCURRENCY=10
# WORKER_HEARTBEAT_INTERVAL_MS=15000
# Multi-region adaptive sync peers, format: us-east=redis://host:6379,eu-west=redis://host:6379
# ADAPTIVE_REDIS_PEERS=

# Public Reputation Shield API. If set, clients must send `x-api-key`.
# REPUTATION_PUBLIC_API_KEY=change_me
# Database-backed public API keys are preferred. Generate one with:
#   pnpm public-api-key:create -- --name "Partner" --tier free
PUBLIC_REPUTATION_FREE_DAILY_LIMIT=10
PUBLIC_REPUTATION_PRO_DAILY_LIMIT=1000
PUBLIC_REPUTATION_ENTERPRISE_DAILY_LIMIT=100000
PUBLIC_REPUTATION_BLACKLIST_CACHE_SEC=21600

# Local-only content mutation. Disabled by default. Enable only with an approved
# local Ollama/local-LLM endpoint; no client email content is sent to external APIs.
CONTENT_MUTATION_ENABLED=false
CONTENT_MUTATION_ENDPOINT=http://127.0.0.1:11434/api/generate
CONTENT_MUTATION_MODEL=llama3:8b
CONTENT_MUTATION_POOL_SIZE=500
CONTENT_MUTATION_FILL_PER_LOCK=500
CONTENT_MUTATION_TIMEOUT_MS=12000
CONTENT_MUTATION_POOL_TTL_SEC=86400

# Hidden investor view assumptions (`/reputation?investor=1`)
# INVESTOR_LEAD_VALUE_USD=1
# COST_PER_SEND=0.002

# Advanced decision flags (safe defaults: OFF)
SIMULATION_ENABLED=false
INTELLIGENCE_ENABLED=false
ADVANCED_DECISION_ENABLED=false
ADVANCED_DECISION_SAMPLE_PCT=5
PRE_ENQUEUE_ADAPTER_TIMEOUT_MS=1500
PRE_ENQUEUE_TOTAL_BUDGET_MS=2500
OUTCOME_ENABLED=false
OUTCOME_EXPERIMENT=false
SAFE_MODE=false
COST_PER_SEND=0
