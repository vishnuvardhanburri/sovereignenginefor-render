{
  "name": "sovereign-engine-root",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "node scripts/sync-env.mjs && pnpm -C apps/api-gateway dev",
    "build": "node scripts/sync-env.mjs && pnpm -C apps/api-gateway build",
    "typecheck": "pnpm -C apps/api-gateway exec tsc --noEmit --pretty false",
    "start": "node scripts/sync-env.mjs && pnpm -C apps/api-gateway start",
    "lint": "pnpm -C apps/api-gateway lint",
    "db:init": "node scripts/sync-env.mjs && pnpm -C apps/api-gateway db:init",
    "db:rls": "node scripts/sync-env.mjs && pnpm -C apps/api-gateway tenant:rls",
    "audit:anchor": "node scripts/sync-env.mjs && pnpm -C apps/api-gateway audit:anchor",
    "secret:rotate": "node scripts/sync-env.mjs && pnpm -C apps/api-gateway secret:rotate",
    "env:check": "node scripts/sync-env.mjs && pnpm -C apps/api-gateway env:check",
    "prod:check": "node scripts/final-production-check.mjs",
    "prod:check:real": "node scripts/final-production-check.mjs --real-send",
    "brand:check": "node scripts/check-branding.mjs",
    "copy:check": "node scripts/check-buyer-copy.mjs",
    "platform:check": "node scripts/check-platform-consoles.mjs",
    "realtime:dev": "pnpm -C apps/realtime-gateway dev",
    "desktop:dev": "pnpm -C apps/desktop-console dev",
    "mobile:dev": "pnpm -C apps/mobile-console dev",
    "doctor:demo": "node scripts/demo-doctor.mjs",
    "qa:demo": "node scripts/demo-browser-qa.mjs",
    "qa:demo:headed": "node scripts/demo-browser-qa.mjs --headed",
    "qa:enterprise": "node scripts/enterprise-qa.mjs",
    "submit:pack": "node scripts/submit-pack.mjs",
    "submit:pack:qa": "node scripts/submit-pack.mjs --with-qa",
    "buyer:proof": "node scripts/buyer-proof-report.mjs",
    "launch:ready": "node scripts/launch-ready.mjs",
    "deploy:production": "node scripts/deploy-production.mjs",
    "generate:data-room": "node scripts/generate-data-room.mjs",
    "sales:ready": "node scripts/sales-ready.mjs",
    "operator:e2e": "node scripts/operator-e2e-check.mjs",
    "outbound:prepare": "node scripts/prepare-outbound-leads.mjs",
    "cloud:cron": "node scripts/sync-env.mjs && node scripts/cloud-outbound-cron.mjs",
    "ready:launch": "node scripts/launch-ready.mjs",
    "launch:stop": "docker compose -f docker-compose.prod.yml down",
    "demo:buyer": "node scripts/buyer-demo.mjs",
    "demo:investor": "node scripts/demo-investor.mjs",
    "demo:buyer:stress": "node scripts/buyer-demo.mjs --stress-count=10000",
    "demo:buyer:stop": "node scripts/buyer-demo.mjs --stop",
    "demo:clips": "python3 scripts/generate-demo-clips.py",
    "demo:package": "node scripts/package-demo-clips.mjs",
    "user:create": "node scripts/sync-env.mjs && pnpm -C apps/api-gateway user:create",
    "public-api-key:create": "node scripts/sync-env.mjs && pnpm -C apps/api-gateway public-api-key:create",
    "demo:outbound": "node scripts/sync-env.mjs && pnpm --dir apps/api-gateway exec tsx scripts/demo-outbound.ts",
    "send:test": "node scripts/sync-env.mjs && pnpm --dir apps/api-gateway exec tsx scripts/send-test.ts",
    "outbound:send": "node scripts/sync-env.mjs && pnpm --dir apps/api-gateway exec tsx scripts/outbound-send.ts",
    "stress:test": "node scripts/sync-env.mjs && DOTENV_CONFIG_PATH=\"$(pwd)/.env\" pnpm -C internal stress:test",
    "stress:prod": "node scripts/stress-prod.mjs",
    "validator:api": "pnpm -C services/validator-engine validator:api",
    "validator:worker": "pnpm -C services/validator-engine validator:worker",
    "worker:sender": "node scripts/sync-env.mjs && DOTENV_CONFIG_PATH=\"$(pwd)/.env\" pnpm -C workers/sender-worker worker:dev",
    "worker:reputation": "node scripts/sync-env.mjs && DOTENV_CONFIG_PATH=\"$(pwd)/.env\" pnpm -C workers/reputation-worker worker:dev",
    "worker:optimizer": "node scripts/sync-env.mjs && DOTENV_CONFIG_PATH=\"$(pwd)/.env\" pnpm -C workers/optimizer-worker worker:dev",
    "worker:inbound": "node scripts/sync-env.mjs && DOTENV_CONFIG_PATH=\"$(pwd)/.env\" pnpm -C workers/inbound-worker worker:dev",
    "tool:api": "pnpm -C services/tool-api tool:api"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
